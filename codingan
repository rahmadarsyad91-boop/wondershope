<?php

namespace App\Http\Controllers;

use Illuminate\Http\Request;
use App\Models\Product;
use App\Models\ProductVariant;

class CartController extends Controller
{
    // 1. Menampilkan Halaman Keranjang
    public function index()
    {
        $cart = session()->get('cart', []);
        return view('cart.index', compact('cart'));
    }

    // 2. Memasukkan Produk & Varian ke Keranjang
    public function add(Request $request)
    {
        $request->validate([
            'product_id' => 'required',
            'variant_id' => 'required',
            'quantity' => 'required|numeric|min:1'
        ]);

        $product = Product::findOrFail($request->product_id);
        $variant = ProductVariant::findOrFail($request->variant_id);
        
        $cart = session()->get('cart', []);
        $cartId = $request->product_id . '-' . $request->variant_id; // Unique ID gabungan produk & varian

        // Jika produk dengan varian tersebut sudah ada di keranjang, tambahkan jumlahnya
        if(isset($cart[$cartId])) {
            $cart[$cartId]['quantity'] += $request->quantity;
        } else {
            // Jika belum ada, masukkan data baru
            $cart[$cartId] = [
                "name" => $product->name,
                "brand" => $product->brand,
                "variant_name" => $variant->nama_varian,
                "quantity" => $request->quantity,
                "price" => $product->base_price,
                "slug" => $product->slug
            ];
        }

        session()->put('cart', $cart);
        return redirect()->route('cart.index')->with('success', 'Produk berhasil ditambahkan ke keranjang!');
    }

    // 3. Menghapus Item dari Keranjang
    public function remove($id)
    {
        $cart = session()->get('cart', []);
        if(isset($cart[$id])) {
            unset($cart[$id]);
            session()->put('cart', $cart);
        }
        return redirect()->route('cart.index')->with('success', 'Item berhasil dihapus!');
    }
}


